'use client';

import { useState, useRef, useEffect, useCallback } from 'react';

import { motion } from 'framer-motion';

/* ─── Brainstorm Web Round Data ─── */
const ROUNDS = [
  {
    round: 1,
    title: 'Initial Burst',
    color: '#ec4899',
    glow: 'rgba(236,72,153,0.15)',
    desc: 'Rapid-fire ideas with no filtering. Quantity over quality. Aim for 10+ ideas.',
    prompt: 'What are ALL the ideas that come to mind, even wild or impossible ones?',
    fallbackPrompts: [
      'What are the first ideas that pop into your head?',
      'What if you threw out all constraints?',
      'What would someone 5 years old suggest?',
      'What would the opposite idea look like?',
    ],
    icon: '💥',
  },
  {
    round: 2,
    title: 'Build & Combine',
    color: '#ec4899',
    glow: 'rgba(236,72,153,0.15)',
    desc: 'Take ideas you already have and build on them, combine them, or remix them.',
    prompt: 'How can you combine, merge, or build on your existing ideas?',
    fallbackPrompts: [
      'What if you merged two of your ideas?',
      'How could you push one idea further?',
      'What if you combined the best parts of different ideas?',
      'What happens if you add a constraint to an idea?',
    ],
    icon: '🔄',
  },
  {
    round: 3,
    title: 'Wild Ideas',
    color: '#ec4899',
    glow: 'rgba(236,72,153,0.15)',
    desc: 'Push for impossible or absurd ideas, then find the kernel of possibility.',
    prompt: 'What\'s the most outrageous idea you can imagine?',
    fallbackPrompts: [
      'What if you ignored all budget, physics, or logic?',
      'What would a sci-fi solution look like?',
      'What would aliens or robots suggest?',
      'What if failure was impossible?',
    ],
    icon: '🚀',
  },
] as const;

type RoundIndex = 0 | 1 | 2;
type EffortLevel = 'low' | 'medium' | 'high';

interface BrainstormWebToolProps {
  toolId?: string;
  mode: 'public' | 'embedded' | 'standalone';
  challenge?: string;
  sessionId?: string;
  onSave?: (state: ToolState) => void;
  onComplete?: (data: ToolResponse) => void;
}

interface ToolState {
  stage: 'intro' | 'working' | 'summary';
  challenge: string;
  currentRound: RoundIndex;
  ideas: string[][];
  ideaEfforts: Record<number, EffortLevel[]>;
  dealtCards: Record<number, number>;
}

interface ToolResponse {
  toolId: string;
  challenge: string;
  stage: 'intro' | 'working' | 'summary';
  ideas: string[][];
  metadata: {
    totalIdeas: number;
    timeSpentMs: number;
  };
}

/* ─── Effort Assessment (client-side, deterministic) ─── */
function assessEffort(idea: string): EffortLevel {
  const words = idea.trim().split(/\s+/).length;
  const hasReasoning = /\b(because|since|so that|in order to|this would|this could|which means|that way)\b/i.test(idea);
  const hasSpecifics = /\b(for example|such as|like|using|made of|instead of|rather than|compared to)\b/i.test(idea);
  const hasDetail = words >= 15;

  if (words < 6) return 'low';
  if ((hasDetail && hasSpecifics) || (hasDetail && hasReasoning) || (hasSpecifics && hasReasoning)) return 'high';
  if (words >= 10 || hasSpecifics || hasReasoning) return 'medium';
  return 'low';
}

const MICRO_FEEDBACK: Record<EffortLevel, { emoji: string; messages: string[] }> = {
  high: {
    emoji: '✦',
    messages: ['Deep thinking!', 'Great detail!', 'Specific and clear!', 'Well thought out!', 'Love the creativity!'],
  },
  medium: {
    emoji: '→',
    messages: ['Good — keep pushing!', 'Nice idea!', 'Getting momentum!', 'Building something!'],
  },
  low: {
    emoji: '↑',
    messages: ['Keep going!', 'What would that look like?', 'Tell me more!'],
  },
};

/* ─── Main Component ─── */
export function BrainstormWebTool({
  mode = 'public',
  challenge: initialChallenge = '',
  sessionId: initialSessionId,
  onSave,
  onComplete,
}: BrainstormWebToolProps) {
  const [stage, setStage] = useState<'intro' | 'working' | 'summary'>(
    initialChallenge ? 'working' : 'intro'
  );
  const [challenge, setChallenge] = useState(initialChallenge);
  const [currentRound, setCurrentRound] = useState<RoundIndex>(0);
  const [ideas, setIdeas] = useState<string[][]>(() => ROUNDS.map(() => []));
  const [currentIdea, setCurrentIdea] = useState('');
  const [animatingRound, setAnimatingRound] = useState(false);

  // AI state
  const [sessionId] = useState(() => initialSessionId || Math.random().toString(36).slice(2) + Date.now().toString(36));
  const [aiPrompts, setAiPrompts] = useState<Record<number, string[]>>({});
  const [loadingPrompts, setLoadingPrompts] = useState(false);
  const [nudge, setNudge] = useState('');
  const [nudgeVisible, setNudgeVisible] = useState(false);
  const [loadingNudge, setLoadingNudge] = useState(false);
  const [insights, setInsights] = useState('');
  const [loadingInsights, setLoadingInsights] = useState(false);

  // Card dealing state
  const [dealtCards, setDealtCards] = useState<Record<number, number>>({});
  const [thinkingTimeLeft, setThinkingTimeLeft] = useState(0);
  const thinkingTimerRef = useRef<ReturnType<typeof setInterval> | null>(null);

  // Effort-gating & micro-feedback state
  const [ideaEfforts, setIdeaEfforts] = useState<Record<number, EffortLevel[]>>({});
  const [microFeedback, setMicroFeedback] = useState<{ effort: EffortLevel; message: string } | null>(null);
  const [nudgeAcknowledgment, setNudgeAcknowledgment] = useState('');
  const microFeedbackTimerRef = useRef<ReturnType<typeof setTimeout> | null>(null);

  const textareaRef = useRef<HTMLTextAreaElement>(null);
  const challengeRef = useRef<HTMLTextAreaElement>(null);

  const round = ROUNDS[currentRound];
  const totalIdeas = ideas.reduce((sum, arr) => sum + arr.length, 0);
  const currentPrompts = aiPrompts[currentRound] || round.fallbackPrompts;
  const cardsDealt = dealtCards[currentRound] || 0;

  // Auto-save state when in embedded mode
  useEffect(() => {
    if (mode !== 'public' && onSave) {
      const timer = setTimeout(() => {
        const state: ToolState = {
          stage,
          challenge,
          currentRound,
          ideas,
          ideaEfforts,
          dealtCards,
        };
        onSave(state);
      }, 1000);

      return () => clearTimeout(timer);
    }
  }, [stage, challenge, currentRound, ideas, ideaEfforts, dealtCards, mode, onSave]);

  const fetchAI = useCallback(async (body: Record<string, unknown>): Promise<Record<string, unknown>> => {
    const res = await fetch('/api/tools/brainstorm-web', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });
    if (!res.ok) {
      const err = await res.json().catch(() => ({ error: 'Request failed' }));
      throw new Error(err.error || `HTTP ${res.status}`);
    }
    return res.json();
  }, []);

  const fetchPrompts = useCallback(async (roundIdx: number, existingIdeas: string[] = []) => {
    if (!challenge.trim()) return;
    setLoadingPrompts(true);
    try {
      const data = await fetchAI({
        action: 'prompts',
        challenge: challenge.trim(),
        sessionId,
        roundIndex: roundIdx,
        existingIdeas,
      });
      if (data.prompts && Array.isArray(data.prompts)) {
        setAiPrompts(prev => ({ ...prev, [roundIdx]: data.prompts as string[] }));
      }
    } catch (err) {
      console.warn('[brainstorm-web] AI prompts unavailable:', err);
    } finally {
      setLoadingPrompts(false);
    }
  }, [challenge, sessionId, fetchAI]);

  const fetchNudge = useCallback(async (idea: string, roundIdx: number, allRoundIdeas: string[], effort: EffortLevel) => {
    setLoadingNudge(true);
    setNudgeVisible(true);
    setNudgeAcknowledgment('');
    try {
      const data = await fetchAI({
        action: 'nudge',
        challenge: challenge.trim(),
        sessionId,
        roundIndex: roundIdx,
        idea,
        existingIdeas: allRoundIdeas,
        effortLevel: effort,
      });
      if (data.nudge) setNudge(data.nudge as string);
      if (data.acknowledgment) setNudgeAcknowledgment(data.acknowledgment as string);
    } catch (err) {
      console.warn('[brainstorm-web] AI nudge unavailable:', err);
      setNudgeVisible(false);
    } finally {
      setLoadingNudge(false);
    }
  }, [challenge, sessionId, fetchAI]);

  const fetchInsights = useCallback(async () => {
    if (totalIdeas === 0) return;
    setLoadingInsights(true);
    try {
      const data = await fetchAI({
        action: 'insights',
        challenge: challenge.trim(),
        sessionId,
        allIdeas: ideas,
      });
      if (data.insights) setInsights(data.insights as string);
    } catch (err) {
      console.warn('[brainstorm-web] AI insights unavailable:', err);
    } finally {
      setLoadingInsights(false);
    }
  }, [challenge, sessionId, ideas, totalIdeas, fetchAI]);

  // Auto-focus textarea on round change
  useEffect(() => {
    if (stage === 'working' && textareaRef.current) {
      setTimeout(() => textareaRef.current?.focus(), 350);
    }
  }, [currentRound, stage]);

  // Auto-focus challenge input
  useEffect(() => {
    if (stage === 'intro' && challengeRef.current) {
      setTimeout(() => challengeRef.current?.focus(), 500);
    }
  }, [stage]);

  // Fetch prompts when entering a round
  useEffect(() => {
    if (stage === 'working' && !aiPrompts[currentRound]) {
      fetchPrompts(currentRound, ideas[currentRound]);
    }
  }, [stage, currentRound, aiPrompts, ideas, fetchPrompts]);

  // Fetch insights when entering summary
  useEffect(() => {
    if (stage === 'summary' && totalIdeas > 0 && !insights) {
      fetchInsights();
    }
  }, [stage, insights, totalIdeas, fetchInsights]);

  const startWorking = () => {
    if (!challenge.trim()) return;
    setStage('working');
  };

  const addIdea = useCallback(() => {
    if (!currentIdea.trim()) return;
    const newIdea = currentIdea.trim();
    const effort = assessEffort(newIdea);

    setIdeas(prev => {
      const next = [...prev];
      next[currentRound] = [...next[currentRound], newIdea];
      return next;
    });

    setIdeaEfforts(prev => ({
      ...prev,
      [currentRound]: [...(prev[currentRound] || []), effort],
    }));

    const feedbackPool = MICRO_FEEDBACK[effort];
    const message = feedbackPool.messages[Math.floor(Math.random() * feedbackPool.messages.length)];
    setMicroFeedback({ effort, message });

    if (microFeedbackTimerRef.current) clearTimeout(microFeedbackTimerRef.current);
    microFeedbackTimerRef.current = setTimeout(() => setMicroFeedback(null), 3000);

    setCurrentIdea('');
    setNudge('');
    setNudgeAcknowledgment('');
    textareaRef.current?.focus();

    const updatedIdeas = [...ideas[currentRound], newIdea];
    fetchNudge(newIdea, currentRound, updatedIdeas, effort);
  }, [currentIdea, currentRound, ideas, fetchNudge]);

  const goToRound = (idx: RoundIndex) => {
    if (idx === currentRound) return;
    setAnimatingRound(true);
    setNudge('');
    setNudgeVisible(false);
    setTimeout(() => {
      setCurrentRound(idx);
      setCurrentIdea('');
      setTimeout(() => setAnimatingRound(false), 50);
    }, 200);
  };

  const nextRound = () => {
    if (currentRound < 2) goToRound((currentRound + 1) as RoundIndex);
    else {
      setInsights('');
      setStage('summary');
      if (onComplete) {
        onComplete({
          toolId: 'brainstorm-web',
          challenge,
          stage: 'summary',
          ideas,
          metadata: {
            totalIdeas,
            timeSpentMs: 0,
          },
        });
      }
    }
  };

  const prevRound = () => {
    if (currentRound > 0) goToRound((currentRound - 1) as RoundIndex);
  };

  // Clean up timers on unmount
  useEffect(() => {
    return () => {
      if (thinkingTimerRef.current) clearInterval(thinkingTimerRef.current);
      if (microFeedbackTimerRef.current) clearTimeout(microFeedbackTimerRef.current);
    };
  }, []);

  // Reset thinking timer when changing rounds
  useEffect(() => {
    setThinkingTimeLeft(0);
    setMicroFeedback(null);
    if (thinkingTimerRef.current) clearInterval(thinkingTimerRef.current);
    if (microFeedbackTimerRef.current) clearTimeout(microFeedbackTimerRef.current);
  }, [currentRound]);

  const startOver = () => {
    setStage('intro');
    setChallenge('');
    setCurrentRound(0);
    setIdeas(ROUNDS.map(() => []));
    setCurrentIdea('');
    setAiPrompts({});
    setNudge('');
    setNudgeVisible(false);
    setNudgeAcknowledgment('');
    setInsights('');
    setIdeaEfforts({});
    setMicroFeedback(null);
    setDealtCards({});
  };

  const handlePrint = () => window.print();

  /* ─── INTRO SCREEN ─── */
  if (stage === 'intro') {
    return (
        style={{
        background: '#06060f',
        color: '#e8eaf0',
        minHeight: '100vh',
        fontFamily: 'Inter, -apple-system, sans-serif',
        display: 'flex',
        flexDirection: 'column',
        alignItems: 'center',
        justifyContent: 'center',
        padding: '40px 24px',
        position: 'relative',
        overflow: 'hidden',
      }}>
        <style>{`
          @keyframes float { 0%, 100% { transform: translateY(0px); } 50% { transform: translateY(-10px); } }
          @keyframes fadeInUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
          @media print { .no-print { display: none !important; } }
        `}</style>

        <div style={{
          position: 'absolute',
          top: '20%',
          left: '50%',
          transform: 'translate(-50%, -50%)',
          width: '600px',
          height: '600px',
          background: 'radial-gradient(circle, rgba(236,72,153,0.08) 0%, transparent 70%)',
          pointerEvents: 'none',
        }} />

        <div style={{
          display: 'flex',
          gap: '16px',
          marginBottom: '48px',
          animation: 'float 6s ease-in-out infinite',
        }}>
          {['💥', '🔄', '🚀'].map((emoji, i) => (
            <div
              key={i}
              style={{
                width: '64px',
                height: '64px',
                borderRadius: '16px',
                background: 'linear-gradient(135deg, #ec4899 20, #ec4899 08)',
                border: '2px solid #ec489940',
                display: 'flex',
                alignItems: 'center',
                justifyContent: 'center',
                fontSize: '32px',
              }}
            >
              {emoji}
            </div>
          ))}
        </div>

        <h1 style={{
          fontSize: 'clamp(32px, 8vw, 56px)',
          fontWeight: '700',
          marginBottom: '16px',
          textAlign: 'center',
          animation: 'fadeInUp 0.8s ease-out',
        }}>
          Brainstorm Web
        </h1>

        <p style={{
          fontSize: 'clamp(16px, 3vw, 20px)',
          color: '#a8aac4',
          marginBottom: '48px',
          maxWidth: '500px',
          textAlign: 'center',
          animation: 'fadeInUp 0.8s ease-out 0.1s both',
        }}>
          Three rounds of rapid brainstorming: burst, build, and wild ideas.
        </p>

        <div style={{
          width: '100%',
          maxWidth: '500px',
          marginBottom: '32px',
          animation: 'fadeInUp 0.8s ease-out 0.2s both',
        }}>
          <label style={{
            display: 'block',
            fontSize: '14px',
            fontWeight: '600',
            color: '#d8dce6',
            marginBottom: '12px',
          }}>
            What's your design challenge?
          </label>
          <textarea
            ref={challengeRef}
            value={challenge}
            onChange={(e) => setChallenge(e.target.value)}
            placeholder="E.g., How to reduce food waste, Better study techniques, More engaging lessons..."
            style={{
              width: '100%',
              padding: '16px',
              fontSize: '16px',
              fontFamily: 'inherit',
              borderRadius: '12px',
              border: '2px solid #2a2d3a',
              background: '#0f1119',
              color: '#e8eaf0',
              resize: 'vertical',
              minHeight: '120px',
              transition: 'border-color 0.3s, box-shadow 0.3s',
            }}
            onFocus={(e) => {
              e.currentTarget.style.borderColor = '#ec4899';
              e.currentTarget.style.boxShadow = '0 0 0 3px rgba(236,72,153,0.1)';
            }}
            onBlur={(e) => {
              e.currentTarget.style.borderColor = '#2a2d3a';
              e.currentTarget.style.boxShadow = 'none';
            }}
          />
        </div>

        <button
          onClick={startWorking}
          disabled={!challenge.trim()}
          style={{
            padding: '14px 40px',
            fontSize: '16px',
            fontWeight: '600',
            borderRadius: '10px',
            border: 'none',
            background: challenge.trim() ? '#ec4899' : '#5a5d6f',
            color: '#fff',
            cursor: challenge.trim() ? 'pointer' : 'not-allowed',
            transition: 'all 0.3s',
            animation: 'fadeInUp 0.8s ease-out 0.3s both',
          }}
          onMouseEnter={(e) => {
            if (challenge.trim()) {
              e.currentTarget.style.background = '#be185d';
            }
          }}
          onMouseLeave={(e) => {
            if (challenge.trim()) {
              e.currentTarget.style.background = '#ec4899';
            }
          }}
        >
          Start Brainstorming
        </button>
      </div>
    );
  }

  /* ─── WORKING SCREEN ─── */
  if (stage === 'working') {
    return (
        style={{
        background: '#06060f',
        color: '#e8eaf0',
        minHeight: '100vh',
        fontFamily: 'Inter, -apple-system, sans-serif',
        padding: '40px 24px',
      }}>
        <style>{`
          @keyframes fadeInUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
          @keyframes celebrateGlow { 0%, 100% { opacity: 0; transform: scale(1); } 50% { opacity: 1; transform: scale(1.1); } }
          @keyframes softBounce { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }
          @media print { .no-print { display: none !important; } }
        `}</style>

        <div className="no-print" style={{ maxWidth: '800px', margin: '0 auto', marginBottom: '40px' }}>
          {/* Round Navigation */}
          <div style={{
            display: 'flex',
            gap: '8px',
            marginBottom: '32px',
            flexWrap: 'wrap',
          }}>
            {ROUNDS.map((r, idx) => (
              <button
                key={idx}
                onClick={() => goToRound(idx as RoundIndex)}
                disabled={animatingRound}
                style={{
                  padding: '10px 16px',
                  fontSize: '13px',
                  fontWeight: '600',
                  borderRadius: '8px',
                  border: '2px solid',
                  borderColor: idx === currentRound ? r.color : '#2a2d3a',
                  background: idx === currentRound ? `${r.color}20` : 'transparent',
                  color: idx === currentRound ? r.color : '#a8aac4',
                  cursor: animatingRound ? 'not-allowed' : 'pointer',
                  transition: 'all 0.3s',
                  opacity: animatingRound ? 0.5 : 1,
                }}
                onMouseEnter={(e) => {
                  if (idx !== currentRound && !animatingRound) {
                    e.currentTarget.style.borderColor = r.color;
                    e.currentTarget.style.color = r.color;
                  }
                }}
                onMouseLeave={(e) => {
                  if (idx !== currentRound) {
                    e.currentTarget.style.borderColor = '#2a2d3a';
                    e.currentTarget.style.color = '#a8aac4';
                  }
                }}
              >
                {r.round}. {r.title.split(' ')[0]}
              </button>
            ))}
          </div>

          {/* Round Title & Desc */}
          <div style={{ marginBottom: '32px' }}>
            <h2 style={{
              fontSize: '28px',
              fontWeight: '700',
              marginBottom: '12px',
              color: round.color,
            }}>
              {round.title}
            </h2>
            <p style={{
              fontSize: '16px',
              color: '#a8aac4',
              lineHeight: '1.6',
            }}>
              {round.desc}
            </p>
          </div>

          {/* Input Textarea */}
          <div style={{ marginBottom: '24px' }}>
            <textarea
              ref={textareaRef}
              value={currentIdea}
              onChange={(e) => setCurrentIdea(e.target.value)}
              onKeyDown={(e) => {
                if (e.key === 'Enter' && e.ctrlKey) {
                  addIdea();
                }
              }}
              placeholder="Type your idea..."
              style={{
                width: '100%',
                padding: '16px',
                fontSize: '16px',
                fontFamily: 'inherit',
                borderRadius: '12px',
                border: '2px solid #2a2d3a',
                background: '#0f1119',
                color: '#e8eaf0',
                resize: 'vertical',
                minHeight: '100px',
                transition: 'all 0.3s',
              }}
              onFocus={(e) => {
                e.currentTarget.style.borderColor = round.color;
              }}
              onBlur={(e) => {
                e.currentTarget.style.borderColor = '#2a2d3a';
              }}
            />
          </div>

          {/* Add Idea Button */}
          <button
            onClick={addIdea}
            disabled={!currentIdea.trim()}
            style={{
              padding: '12px 24px',
              fontSize: '14px',
              fontWeight: '600',
              borderRadius: '8px',
              border: 'none',
              background: currentIdea.trim() ? round.color : '#5a5d6f',
              color: '#fff',
              cursor: currentIdea.trim() ? 'pointer' : 'not-allowed',
              marginBottom: '24px',
            }}
          >
            Add Idea
          </button>

          {/* Ideas List */}
          {(ideas[currentRound] || []).length > 0 && (
            <div style={{
              marginBottom: '32px',
              padding: '20px',
              borderRadius: '12px',
              background: '#0f1119',
              border: `2px solid ${round.color}20`,
            }}>
              <h3 style={{
                fontSize: '14px',
                fontWeight: '600',
                color: '#a8aac4',
                marginBottom: '16px',
              }}>
                Your Ideas ({ideas[currentRound].length})
              </h3>
              <div style={{ display: 'flex', flexDirection: 'column', gap: '12px' }}>
                {ideas[currentRound].map((idea, idx) => (
                  <div
                    key={idx}
                    style={{
                      padding: '12px',
                      borderRadius: '8px',
                      background: '#1a1d2a',
                      border: `1px solid ${round.color}30`,
                      display: 'flex',
                      justifyContent: 'space-between',
                      alignItems: 'flex-start',
                      gap: '12px',
                    }}
                  >
                    <p style={{
                      fontSize: '14px',
                      color: '#e8eaf0',
                      margin: 0,
                      flex: 1,
                      lineHeight: '1.5',
                    }}>
                      {idea}
                    </p>
                  </div>
                ))}
              </div>
            </div>
          )}

          {/* Micro Feedback Toast */}
          {microFeedback && (
            <div style={{
              position: 'fixed',
              bottom: '40px',
              right: '24px',
              padding: '14px 20px',
              borderRadius: '24px',
              background: microFeedback.effort === 'high' ? '#a78bfa' : microFeedback.effort === 'medium' ? '#60a5fa' : '#f59e0b',
              color: '#fff',
              fontWeight: '600',
              fontSize: '14px',
              boxShadow: '0 8px 16px rgba(0,0,0,0.4)',
              animation: microFeedback.effort === 'high' ? 'celebrateGlow 1s ease-out' : 'softBounce 0.6s ease-out',
              zIndex: 50,
            }}>
              {MICRO_FEEDBACK[microFeedback.effort].emoji} {microFeedback.message}
            </div>
          )}
        </div>

        {/* Navigation Buttons */}
        <div className="no-print" style={{
          display: 'flex',
          gap: '12px',
          justifyContent: 'center',
          maxWidth: '800px',
          margin: '0 auto',
        }}>
          <button
            onClick={prevRound}
            disabled={currentRound === 0 || animatingRound}
            style={{
              padding: '12px 24px',
              fontSize: '14px',
              fontWeight: '600',
              borderRadius: '8px',
              border: 'none',
              background: currentRound === 0 ? '#5a5d6f' : '#2a2d3a',
              color: '#e8eaf0',
              cursor: currentRound === 0 ? 'not-allowed' : 'pointer',
            }}
          >
            ← Back
          </button>

          <button
            onClick={nextRound}
            disabled={animatingRound}
            style={{
              padding: '12px 24px',
              fontSize: '14px',
              fontWeight: '600',
              borderRadius: '8px',
              border: 'none',
              background: round.color,
              color: '#fff',
              cursor: 'pointer',
            }}
          >
            {currentRound === 2 ? 'Finish →' : 'Next →'}
          </button>

          <button
            onClick={handlePrint}
            style={{
              padding: '12px 24px',
              fontSize: '14px',
              fontWeight: '600',
              borderRadius: '8px',
              border: 'none',
              background: '#2a2d3a',
              color: '#e8eaf0',
              cursor: 'pointer',
            }}
          >
            Print
          </button>
        </div>
      </div>
    </div>
    );
  }

  /* ─── SUMMARY SCREEN ─── */
  return (
      style={{
      background: '#06060f',
      color: '#e8eaf0',
      minHeight: '100vh',
      fontFamily: 'Inter, -apple-system, sans-serif',
      padding: '40px 24px',
    }}>
      <div style={{ maxWidth: '800px', margin: '0 auto' }}>
        <h2 style={{
          fontSize: '32px',
          fontWeight: '700',
          marginBottom: '24px',
          textAlign: 'center',
        }}>
          Your Brainstorm Web
        </h2>

        <p style={{
          fontSize: '16px',
          color: '#a8aac4',
          marginBottom: '32px',
          textAlign: 'center',
        }}>
          Challenge: <strong style={{ color: '#e8eaf0' }}>{challenge}</strong>
        </p>

        {/* Ideas by Round */}
        {ROUNDS.map((r, roundIdx) => (
          ideas[roundIdx] && ideas[roundIdx].length > 0 && (
            <div key={roundIdx} style={{ marginBottom: '32px' }}>
              <h3 style={{
                fontSize: '18px',
                fontWeight: '700',
                color: r.color,
                marginBottom: '16px',
              }}>
                {r.title} ({ideas[roundIdx].length})
              </h3>
              <div style={{ display: 'flex', flexDirection: 'column', gap: '12px' }}>
                {ideas[roundIdx].map((idea, ideaIdx) => (
                  <div
                    key={ideaIdx}
                    style={{
                      padding: '12px',
                      borderRadius: '8px',
                      background: '#0f1119',
                      border: `2px solid ${r.color}40`,
                      lineHeight: '1.6',
                      color: '#e8eaf0',
                    }}
                  >
                    {idea}
                  </div>
                ))}
              </div>
            </div>
          )
        ))}

        {/* Total Ideas */}
        <div style={{
          padding: '20px',
          borderRadius: '12px',
          background: '#0f1119',
          border: '2px solid #ec489920',
          marginBottom: '32px',
          textAlign: 'center',
        }}>
          <p style={{
            fontSize: '18px',
            fontWeight: '700',
            color: '#ec4899',
            margin: 0,
          }}>
            Total Ideas: {totalIdeas}
          </p>
        </div>

        {/* AI Insights */}
        {insights && (
          <div style={{
            padding: '20px',
            borderRadius: '12px',
            background: '#0f1119',
            border: '2px solid #ec489940',
            marginBottom: '32px',
            lineHeight: '1.8',
            color: '#d8dce6',
          }}>
            <h4 style={{ color: '#ec4899', marginTop: 0 }}>AI Insights</h4>
            {insights}
          </div>
        )}

        {loadingInsights && (
          <p style={{ color: '#a8aac4', textAlign: 'center' }}>Generating insights...</p>
        )}

        {/* Actions */}
        <div style={{
          display: 'flex',
          gap: '12px',
          justifyContent: 'center',
        }}>
          <button
            onClick={startOver}
            style={{
              padding: '12px 24px',
              fontSize: '14px',
              fontWeight: '600',
              borderRadius: '8px',
              border: 'none',
              background: '#2a2d3a',
              color: '#e8eaf0',
              cursor: 'pointer',
            }}
          >
            Start Over
          </button>

          <button
            onClick={handlePrint}
            style={{
              padding: '12px 24px',
              fontSize: '14px',
              fontWeight: '600',
              borderRadius: '8px',
              border: 'none',
              background: '#ec4899',
              color: '#fff',
              cursor: 'pointer',
            }}
          >
            Print Results
          </button>
        </div>
      </div>
    </div>
    );
  }
}
