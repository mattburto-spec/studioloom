'use client';

import { useState, useRef, useEffect, useCallback } from 'react';


type EffortLevel = 'low' | 'medium' | 'high';
type StageType = 'intro' | 'params' | 'options' | 'combinations' | 'summary';

/* ─── Effort Assessment ─── */
function assessEffort(text: string): EffortLevel {
  const words = text.trim().split(/\s+/).length;
  const hasReasoning = /\b(because|since|so that|in order to|this would|this could|which means|that way)\b/i.test(text);
  const hasSpecifics = /\b(for example|such as|like|using|made of|instead of|rather than|compared to)\b/i.test(text);
  const hasDetail = words >= 15;

  if (words < 6) return 'low';
  if ((hasDetail && hasSpecifics) || (hasDetail && hasReasoning) || (hasSpecifics && hasReasoning)) return 'high';
  if (words >= 10 || hasSpecifics || hasReasoning) return 'medium';
  return 'low';
}

const MICRO_FEEDBACK: Record<EffortLevel, { emoji: string; messages: string[] }> = {
  high: {
    emoji: '✦',
    messages: ['Deep thinking!', 'Great variety!', 'Strong reasoning!'],
  },
  medium: {
    emoji: '→',
    messages: ['Good ideas!', 'Keep going!', 'Building momentum!'],
  },
  low: {
    emoji: '↑',
    messages: ['Try adding more detail', 'Can you be more specific?'],
  },
};

/* ─── API ─── */
async function fetchAI(body: Record<string, unknown>): Promise<Record<string, unknown>> {
  const res = await fetch('/api/tools/morphological-chart', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(body),
  });
  if (!res.ok) {
    const err = await res.json().catch(() => ({ error: 'Request failed' }));
    throw new Error(err.error || `HTTP ${res.status}`);
  }
  return res.json();
}

/* ─── Main Component ─── */
export function MorphologicalChartTool(props: { toolId?: string; mode: 'public' | 'embedded' | 'standalone'; challenge?: string; sessionId?: string; onSave?: (state: any) => void; onComplete?: (data: any) => void } = { mode: 'public' }) {
  const [stage, setStage] = useState<StageType>('intro');
  const [challenge, setChallenge] = useState('');
  const [parameters, setParameters] = useState<string[]>(['', '', '', '', '']);
  const [options, setOptions] = useState<string[][]>(Array(5).fill(null).map(() => ['', '', '', '']));
  const [selectedParamIdx, setSelectedParamIdx] = useState(0);
  const [combinations, setCombinations] = useState<Array<{ combo: string[]; idea?: string }>>([]);
  const [currentComboIdea, setCurrentComboIdea] = useState('');
  const [currentComboIdx, setCurrentComboIdx] = useState(0);
  const [highlightedCombos, setHighlightedCombos] = useState<Array<{ combo: string[] }>>([]);

  const [sessionId] = useState(() => Math.random().toString(36).slice(2) + Date.now().toString(36));
  const [nudge, setNudge] = useState('');
  const [nudgeVisible, setNudgeVisible] = useState(false);
  const [loadingNudge, setLoadingNudge] = useState(false);
  const [nudgeAcknowledgment, setNudgeAcknowledgment] = useState('');
  const [insights, setInsights] = useState('');
  const [loadingInsights, setLoadingInsights] = useState(false);

  const [microFeedback, setMicroFeedback] = useState<{ effort: EffortLevel; message: string } | null>(null);
  const microFeedbackTimerRef = useRef<ReturnType<typeof setTimeout> | null>(null);
  const challengeRef = useRef<HTMLTextAreaElement>(null);

  /* ─── Fetch nudge ─── */
  const fetchNudge = useCallback(async (combo: string[], idea: string, effort: EffortLevel) => {
    setLoadingNudge(true);
    setNudgeVisible(true);
    setNudgeAcknowledgment('');
    try {
      const data = await fetchAI({
        action: 'nudge',
        challenge: challenge.trim(),
        parameters,
        combination: combo,
        idea,
        sessionId,
        effortLevel: effort,
      });
      if (data.nudge) {
        setNudge(data.nudge as string);
      }
      if (data.acknowledgment) {
        setNudgeAcknowledgment(data.acknowledgment as string);
      }
    } catch (err) {
      console.warn('[morphological] Nudge unavailable:', err);
      setNudgeVisible(false);
    } finally {
      setLoadingNudge(false);
    }
  }, [challenge, parameters, sessionId]);

  /* ─── Fetch insights ─── */
  const fetchInsights = useCallback(async () => {
    const hasIdeas = combinations.some(c => c.idea?.trim());
    if (!hasIdeas) return;
    setLoadingInsights(true);
    try {
      const data = await fetchAI({
        action: 'insights',
        challenge: challenge.trim(),
        parameters,
        combinations: combinations.map(c => ({ combo: c.combo, idea: c.idea })),
        sessionId,
      });
      if (data.insights) {
        setInsights(data.insights as string);
      }
    } catch (err) {
      console.warn('[morphological] Insights unavailable:', err);
    } finally {
      setLoadingInsights(false);
    }
  }, [challenge, parameters, combinations, sessionId]);

  /* ─── Micro-feedback auto-dismiss ─── */
  useEffect(() => {
    if (microFeedback) {
      microFeedbackTimerRef.current = setTimeout(() => setMicroFeedback(null), 3000);
      return () => {
        if (microFeedbackTimerRef.current) clearTimeout(microFeedbackTimerRef.current);
      };
    }
  }, [microFeedback]);

  /* ─── Generate combinations ─── */
  const generateCombinations = () => {
    const filledParams = parameters.filter(p => p.trim());
    if (filledParams.length < 3) {
      alert('Please fill in at least 3 parameters.');
      return;
    }

    const paramIndices = parameters
      .map((p, i) => (p.trim() ? i : -1))
      .filter(i => i !== -1);

    const filledOptions = paramIndices.map(i => options[i].filter(o => o.trim()));

    if (filledOptions.some(opts => opts.length === 0)) {
      alert('Please fill in at least 1 option for each parameter.');
      return;
    }

    // Generate combinations (limit to 12 to avoid overwhelming)
    const combos: Array<{ combo: string[] }> = [];
    const maxCombos = 12;

    if (filledOptions.reduce((a, b) => a * b.length, 1) > maxCombos) {
      // Sample randomly
      for (let i = 0; i < maxCombos; i++) {
        const combo = paramIndices.map(paramIdx => {
          const opts = filledOptions[paramIndices.indexOf(paramIdx)];
          return opts[Math.floor(Math.random() * opts.length)];
        });
        combos.push({ combo });
      }
    } else {
      // Generate all (cartesian product)
      const generateCartesian = (arrays: string[][]): string[][] => {
        if (arrays.length === 0) return [[]];
        if (arrays.length === 1) return arrays[0].map(x => [x]);
        const smaller = generateCartesian(arrays.slice(1));
        return arrays[0].flatMap(x => smaller.map(combo => [x, ...combo]));
      };
      const allCombos = generateCartesian(filledOptions);
      combos.push(...allCombos.slice(0, maxCombos).map(combo => ({ combo })));
    }

    setCombinations(combos);
    setStage('combinations');
  };

  /* ─── Event Handlers ─── */
  const handleAddOption = () => {
    const newOptions = options.map(opts => [...opts]);
    newOptions[selectedParamIdx] = [...newOptions[selectedParamIdx], ''];
    setOptions(newOptions);
  };

  const handleUpdateParameter = (idx: number, value: string) => {
    const newParams = [...parameters];
    newParams[idx] = value;
    setParameters(newParams);
  };

  const handleUpdateOption = (paramIdx: number, optIdx: number, value: string) => {
    const newOptions = options.map(opts => [...opts]);
    newOptions[paramIdx] = [...newOptions[paramIdx]];
    newOptions[paramIdx][optIdx] = value;
    setOptions(newOptions);
  };

  const handleAddCombinationIdea = () => {
    if (!currentComboIdea.trim()) return;

    const effort = assessEffort(currentComboIdea);
    const newCombinations = [...combinations];
    newCombinations[currentComboIdx].idea = currentComboIdea;
    setCombinations(newCombinations);

    const feedback = MICRO_FEEDBACK[effort];
    setMicroFeedback({
      effort,
      message: feedback.messages[Math.floor(Math.random() * feedback.messages.length)],
    });

    fetchNudge(combinations[currentComboIdx].combo, currentComboIdea, effort);
    setCurrentComboIdea('');
  };

  const handleNextCombo = () => {
    if (currentComboIdx < combinations.length - 1) {
      setCurrentComboIdx(currentComboIdx + 1);
      setCurrentComboIdea('');
      setNudgeVisible(false);
    }
  };

  const handlePrevCombo = () => {
    if (currentComboIdx > 0) {
      setCurrentComboIdx(currentComboIdx - 1);
      setCurrentComboIdea('');
      setNudgeVisible(false);
    }
  };

  const generateHighlightedCombos = () => {
    const filledParams = parameters
      .map((p, i) => (p.trim() ? i : -1))
      .filter(i => i !== -1);

    const filledOptions = filledParams.map(i => options[i].filter(o => o.trim()));
    const combos: Array<{ combo: string[] }> = [];

    for (let c = 0; c < 3; c++) {
      const combo = filledParams.map(paramIdx => {
        const opts = filledOptions[filledParams.indexOf(paramIdx)];
        return opts[Math.floor(Math.random() * opts.length)];
      });
      combos.push({ combo });
    }

    setHighlightedCombos(combos);
  };

  const handleFinish = () => {
    fetchInsights();
    setStage('summary');
  };

  /* ─── Intro Stage ─── */
  if (stage === 'intro') {
    return (
        style={{ minHeight: '100vh', background: 'linear-gradient(135deg, #0f0c24 0%, #1a0818 100%)', padding: '2rem', fontFamily: 'Inter, sans-serif', color: '#fff' }}>
        <div style={{ maxWidth: '600px', margin: '0 auto' }}>
          <div style={{ textAlign: 'center', marginBottom: '3rem' }}>
            <div style={{ fontSize: '3.5rem', marginBottom: '1rem' }}>🔲</div>
            <h1 style={{ fontSize: '2.5rem', fontWeight: '900', margin: '0 0 0.5rem 0' }}>Morphological Chart</h1>
            <p style={{ color: '#d4d4d8', fontSize: '1rem', margin: 0, lineHeight: '1.6' }}>
              Break your design into key parameters, list options for each, then combine them in unexpected ways to discover novel solutions.
            </p>
          </div>

          <div style={{ background: 'rgba(168, 85, 247, 0.08)', border: '1px solid rgba(168, 85, 247, 0.3)', borderRadius: '1rem', padding: '1.5rem', marginBottom: '2rem' }}>
            <label style={{ display: 'block', fontSize: '0.875rem', fontWeight: '600', color: '#a78bfa', marginBottom: '0.5rem' }}>
              What are you designing?
            </label>
            <textarea
              ref={challengeRef}
              value={challenge}
              onChange={e => setChallenge(e.target.value)}
              placeholder="E.g., 'A sustainable water bottle' or 'An inclusive classroom seating system'"
              style={{
                width: '100%',
                padding: '0.75rem',
                background: 'rgba(0, 0, 0, 0.3)',
                border: '1px solid rgba(168, 85, 247, 0.4)',
                borderRadius: '0.5rem',
                color: '#fff',
                fontFamily: 'Inter, sans-serif',
                fontSize: '0.95rem',
                resize: 'vertical',
                minHeight: '80px',
                outline: 'none',
              }}
            />
          </div>

          <button
            onClick={() => setStage('params')}
            disabled={!challenge.trim()}
            style={{
              width: '100%',
              padding: '0.875rem',
              background: challenge.trim() ? 'linear-gradient(135deg, #a855f7 0%, #d946ef 100%)' : 'rgba(168, 85, 247, 0.4)',
              border: 'none',
              borderRadius: '0.75rem',
              color: '#fff',
              fontWeight: '600',
              fontSize: '1rem',
              cursor: challenge.trim() ? 'pointer' : 'not-allowed',
              transition: 'all 0.2s',
            }}
          >
            Start: Define Parameters
          </button>
        </div>
      </div>
    );
  }

  /* ─── Parameters Stage ─── */
  if (stage === 'params') {
    const filledParams = parameters.filter(p => p.trim()).length;

    return (
        style={{ minHeight: '100vh', background: 'linear-gradient(135deg, #0f0c24 0%, #1a0818 100%)', padding: '2rem', fontFamily: 'Inter, sans-serif', color: '#fff' }}>
        <div style={{ maxWidth: '900px', margin: '0 auto' }}>
          <div style={{ marginBottom: '2rem' }}>
            <h1 style={{ fontSize: '2rem', fontWeight: '900', margin: '0 0 0.5rem 0', color: '#a855f7' }}>
              Define Parameters
            </h1>
            <p style={{ color: '#a78bfa', margin: 0, fontSize: '0.9rem' }}>
              {filledParams}/5 parameters filled
            </p>
          </div>

          <div style={{ marginBottom: '2rem' }}>
            <p style={{ fontSize: '0.875rem', fontWeight: '600', color: '#a78bfa', textTransform: 'uppercase', marginBottom: '1rem', letterSpacing: '0.05em' }}>
              Key Design Attributes
            </p>
            <div style={{ display: 'grid', gridTemplateColumns: 'repeat(2, 1fr)', gap: '1rem' }}>
              {parameters.map((param, i) => (
                <input
                  key={i}
                  value={param}
                  onChange={e => handleUpdateParameter(i, e.target.value)}
                  placeholder={`Parameter ${i + 1} (e.g., "Material", "Size")`}
                  style={{
                    padding: '0.75rem',
                    background: 'rgba(0, 0, 0, 0.3)',
                    border: `1px solid rgba(168, 85, 247, ${0.2 + i * 0.05})`,
                    borderRadius: '0.5rem',
                    color: '#fff',
                    fontFamily: 'Inter, sans-serif',
                    fontSize: '0.9rem',
                    outline: 'none',
                  }}
                />
              ))}
            </div>
          </div>

          <button
            onClick={() => {
              if (filledParams < 3) {
                alert('Please fill in at least 3 parameters.');
                return;
              }
              setStage('options');
            }}
            style={{
              width: '100%',
              padding: '0.875rem',
              background: filledParams >= 3 ? 'linear-gradient(135deg, #a855f7 0%, #d946ef 100%)' : 'rgba(168, 85, 247, 0.4)',
              border: 'none',
              borderRadius: '0.75rem',
              color: '#fff',
              fontWeight: '600',
              cursor: filledParams >= 3 ? 'pointer' : 'not-allowed',
              fontSize: '0.95rem',
            }}
          >
            Next: Add Options
          </button>
        </div>
      </div>
    );
  }

  /* ─── Options Stage ─── */
  if (stage === 'options') {
    const currentParam = parameters[selectedParamIdx];
    const currentOptions = options[selectedParamIdx];
    const filledOptions = currentOptions.filter(o => o.trim()).length;
    const filledParams = parameters.map((p, i) => ({ idx: i, param: p })).filter(p => p.param.trim());

    return (
        style={{ minHeight: '100vh', background: 'linear-gradient(135deg, #0f0c24 0%, #1a0818 100%)', padding: '2rem', fontFamily: 'Inter, sans-serif', color: '#fff' }}>
        <div style={{ maxWidth: '900px', margin: '0 auto' }}>
          <div style={{ marginBottom: '2rem' }}>
            <h1 style={{ fontSize: '2rem', fontWeight: '900', margin: '0 0 0.5rem 0', color: '#d946ef' }}>
              {currentParam || 'Add Options'}
            </h1>
            <p style={{ color: '#a78bfa', margin: 0, fontSize: '0.9rem' }}>
              {filledOptions} option(s) defined
            </p>
          </div>

          <div style={{ display: 'grid', gridTemplateColumns: '180px 1fr', gap: '2rem' }}>
            {/* Parameter selector */}
            <div>
              <p style={{ fontSize: '0.8rem', fontWeight: '600', color: '#a78bfa', textTransform: 'uppercase', marginBottom: '0.75rem', letterSpacing: '0.05em' }}>
                Parameters
              </p>
              <div style={{ display: 'flex', flexDirection: 'column', gap: '0.5rem' }}>
                {filledParams.map(p => (
                  <button
                    key={p.idx}
                    onClick={() => setSelectedParamIdx(p.idx)}
                    style={{
                      padding: '0.75rem',
                      background: selectedParamIdx === p.idx ? '#d946ef' : 'rgba(217, 70, 239, 0.2)',
                      border: '1px solid rgba(217, 70, 239, 0.5)',
                      borderRadius: '0.5rem',
                      color: selectedParamIdx === p.idx ? '#fff' : '#d4d4d8',
                      fontWeight: selectedParamIdx === p.idx ? '600' : '500',
                      cursor: 'pointer',
                      fontSize: '0.85rem',
                      transition: 'all 0.2s',
                      textAlign: 'left',
                    }}
                  >
                    {p.param.substring(0, 15)}...
                  </button>
                ))}
              </div>
            </div>

            {/* Options input area */}
            <div>
              <div style={{ marginBottom: '1.5rem' }}>
                <p style={{ fontSize: '0.875rem', fontWeight: '600', color: '#a78bfa', textTransform: 'uppercase', marginBottom: '1rem', letterSpacing: '0.05em' }}>
                  Options for {currentParam}
                </p>
                <div style={{ display: 'flex', flexDirection: 'column', gap: '0.75rem', marginBottom: '1rem' }}>
                  {currentOptions.map((opt, i) => (
                    <input
                      key={i}
                      value={opt}
                      onChange={e => handleUpdateOption(selectedParamIdx, i, e.target.value)}
                      placeholder={`Option ${i + 1}`}
                      style={{
                        padding: '0.75rem',
                        background: 'rgba(0, 0, 0, 0.3)',
                        border: '1px solid rgba(217, 70, 239, 0.4)',
                        borderRadius: '0.5rem',
                        color: '#fff',
                        fontFamily: 'Inter, sans-serif',
                        fontSize: '0.9rem',
                        outline: 'none',
                      }}
                    />
                  ))}
                </div>

                <button
                  onClick={handleAddOption}
                  style={{
                    width: '100%',
                    padding: '0.75rem',
                    background: 'rgba(217, 70, 239, 0.3)',
                    border: '1px solid rgba(217, 70, 239, 0.5)',
                    borderRadius: '0.5rem',
                    color: '#fff',
                    fontWeight: '600',
                    cursor: 'pointer',
                    fontSize: '0.9rem',
                  }}
                >
                  + Add Option
                </button>
              </div>

              {/* Next / Generate Combinations */}
              <div style={{ display: 'flex', gap: '0.75rem' }}>
                {selectedParamIdx < filledParams.length - 1 && (
                  <button
                    onClick={() => setSelectedParamIdx(selectedParamIdx + 1)}
                    style={{
                      flex: 1,
                      padding: '0.875rem',
                      background: 'rgba(217, 70, 239, 0.3)',
                      border: '1px solid rgba(217, 70, 239, 0.5)',
                      borderRadius: '0.75rem',
                      color: '#fff',
                      fontWeight: '600',
                      cursor: 'pointer',
                      fontSize: '0.9rem',
                    }}
                  >
                    Next
                  </button>
                )}
                <button
                  onClick={generateCombinations}
                  disabled={filledParams.some(p => options[p.idx].filter(o => o.trim()).length === 0)}
                  style={{
                    flex: 1,
                    padding: '0.875rem',
                    background: filledParams.every(p => options[p.idx].filter(o => o.trim()).length > 0) ? 'linear-gradient(135deg, #d946ef 0%, #ec4899 100%)' : 'rgba(217, 70, 239, 0.4)',
                    border: 'none',
                    borderRadius: '0.75rem',
                    color: '#fff',
                    fontWeight: '600',
                    cursor: filledParams.every(p => options[p.idx].filter(o => o.trim()).length > 0) ? 'pointer' : 'not-allowed',
                    fontSize: '0.9rem',
                  }}
                >
                  Generate Combinations
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    );
  }

  /* ─── Combinations Stage ─── */
  if (stage === 'combinations' && combinations.length > 0) {
    const combo = combinations[currentComboIdx];
    const hasAllIdeas = combinations.every(c => c.idea?.trim());

    return (
        style={{ minHeight: '100vh', background: 'linear-gradient(135deg, #0f0c24 0%, #1a0818 100%)', padding: '2rem', fontFamily: 'Inter, sans-serif', color: '#fff' }}>
        <div style={{ maxWidth: '900px', margin: '0 auto' }}>
          <div style={{ marginBottom: '2rem' }}>
            <h1 style={{ fontSize: '2rem', fontWeight: '900', margin: '0 0 0.5rem 0', color: '#ec4899' }}>
              Combination {currentComboIdx + 1} / {combinations.length}
            </h1>
            <div style={{ display: 'flex', gap: '0.5rem', flexWrap: 'wrap', marginTop: '0.75rem' }}>
              {combo.combo.map((opt, i) => (
                <span
                  key={i}
                  style={{
                    padding: '0.4rem 0.75rem',
                    background: 'rgba(244, 114, 182, 0.2)',
                    border: '1px solid rgba(244, 114, 182, 0.5)',
                    borderRadius: '999px',
                    fontSize: '0.8rem',
                    fontWeight: '600',
                    color: '#f472b6',
                  }}
                >
                  {opt}
                </span>
              ))}
            </div>
          </div>

          {/* Input Area */}
          <div style={{ background: 'rgba(244, 114, 182, 0.08)', border: '1px solid rgba(244, 114, 182, 0.3)', borderRadius: '0.75rem', padding: '1rem', marginBottom: '1.5rem' }}>
            <label style={{ display: 'block', fontSize: '0.875rem', fontWeight: '600', color: '#f472b6', marginBottom: '0.5rem' }}>
              What concept emerges from this combination?
            </label>
            <textarea
              value={currentComboIdea}
              onChange={e => setCurrentComboIdea(e.target.value)}
              placeholder="Describe the concept, design, or idea this combination suggests..."
              onKeyDown={e => {
                if (e.key === 'Enter' && e.ctrlKey && currentComboIdea.trim()) {
                  handleAddCombinationIdea();
                }
              }}
              style={{
                width: '100%',
                padding: '0.75rem',
                background: 'rgba(0, 0, 0, 0.3)',
                border: '1px solid rgba(244, 114, 182, 0.4)',
                borderRadius: '0.5rem',
                color: '#fff',
                fontFamily: 'Inter, sans-serif',
                fontSize: '0.95rem',
                resize: 'vertical',
                minHeight: '100px',
                outline: 'none',
                marginBottom: '0.75rem',
              }}
            />

            {currentComboIdea.trim() && (
              <button
                onClick={handleAddCombinationIdea}
                style={{
                  width: '100%',
                  padding: '0.75rem',
                  background: 'linear-gradient(135deg, #ec4899 0%, #f472b6 100%)',
                  border: 'none',
                  borderRadius: '0.5rem',
                  color: '#fff',
                  fontWeight: '600',
                  cursor: 'pointer',
                  fontSize: '0.9rem',
                }}
              >
                Save Idea
              </button>
            )}
          </div>

          {/* AI Nudge */}
          {nudgeVisible && (
            <div style={{ background: 'rgba(168, 85, 247, 0.15)', border: '1px solid rgba(168, 85, 247, 0.4)', borderRadius: '0.75rem', padding: '1rem', marginBottom: '1.5rem' }}>
              {loadingNudge ? (
                <p style={{ margin: 0, fontSize: '0.9rem', color: '#d4d4d8' }}>Thinking...</p>
              ) : (
                <>
                  {nudgeAcknowledgment && (
                    <p style={{ margin: '0 0 0.5rem 0', fontSize: '0.85rem', fontWeight: '600', color: '#ec4899' }}>
                      ✦ {nudgeAcknowledgment}
                    </p>
                  )}
                  <p style={{ margin: 0, fontSize: '0.95rem', lineHeight: '1.5', fontStyle: 'italic', color: '#e0d5ff' }}>
                    {nudge}
                  </p>
                </>
              )}
            </div>
          )}

          {/* Navigation */}
          <div style={{ display: 'flex', gap: '0.75rem', marginBottom: '1.5rem' }}>
            <button
              onClick={handlePrevCombo}
              disabled={currentComboIdx === 0}
              style={{
                flex: 1,
                padding: '0.75rem',
                background: currentComboIdx > 0 ? 'rgba(244, 114, 182, 0.3)' : 'rgba(244, 114, 182, 0.1)',
                border: '1px solid rgba(244, 114, 182, 0.3)',
                borderRadius: '0.5rem',
                color: '#fff',
                fontWeight: '600',
                cursor: currentComboIdx > 0 ? 'pointer' : 'not-allowed',
                fontSize: '0.9rem',
              }}
            >
              Previous
            </button>
            <button
              onClick={handleNextCombo}
              disabled={currentComboIdx === combinations.length - 1}
              style={{
                flex: 1,
                padding: '0.75rem',
                background: currentComboIdx < combinations.length - 1 ? 'rgba(244, 114, 182, 0.3)' : 'rgba(244, 114, 182, 0.1)',
                border: '1px solid rgba(244, 114, 182, 0.3)',
                borderRadius: '0.5rem',
                color: '#fff',
                fontWeight: '600',
                cursor: currentComboIdx < combinations.length - 1 ? 'pointer' : 'not-allowed',
                fontSize: '0.9rem',
              }}
            >
              Next
            </button>
            <button
              onClick={handleFinish}
              style={{
                flex: 1,
                padding: '0.75rem',
                background: 'linear-gradient(135deg, #ec4899 0%, #f472b6 100%)',
                border: 'none',
                borderRadius: '0.5rem',
                color: '#fff',
                fontWeight: '600',
                cursor: 'pointer',
                fontSize: '0.9rem',
              }}
            >
              View Summary
            </button>
          </div>
        </div>

        {/* Micro-feedback */}
        {microFeedback && (
          <div
            style={{
              position: 'fixed',
              bottom: '2rem',
              left: '50%',
              transform: 'translateX(-50%)',
              background: microFeedback.effort === 'high' ? '#a78bfa' : microFeedback.effort === 'medium' ? '#60a5fa' : '#f59e0b',
              color: '#000',
              padding: '0.75rem 1.5rem',
              borderRadius: '999px',
              fontWeight: '600',
              fontSize: '0.9rem',
            }}
          >
            {MICRO_FEEDBACK[microFeedback.effort].emoji} {microFeedback.message}
          </div>
        )}
      </div>
    </div>
    );
  }

  /* ─── Summary Stage ─── */
  return (
      style={{ minHeight: '100vh', background: 'linear-gradient(135deg, #0f0c24 0%, #1a0818 100%)', padding: '2rem', fontFamily: 'Inter, sans-serif', color: '#fff' }}>
      <div style={{ maxWidth: '900px', margin: '0 auto' }}>
        <div style={{ marginBottom: '3rem' }}>
          <h1 style={{ fontSize: '2.5rem', fontWeight: '900', margin: '0 0 0.5rem 0' }}>Morphological Summary</h1>
          <p style={{ color: '#a78bfa', margin: 0, fontSize: '0.95rem' }}>
            {combinations.filter(c => c.idea?.trim()).length} / {combinations.length} combinations explored
          </p>
        </div>

        {/* Combination Spotlight */}
        <div style={{ background: 'rgba(244, 114, 182, 0.1)', border: '1px solid rgba(244, 114, 182, 0.3)', borderRadius: '1rem', padding: '2rem', marginBottom: '2rem' }}>
          <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: '1.5rem' }}>
            <h2 style={{ fontSize: '1.1rem', fontWeight: '700', color: '#f472b6', margin: 0 }}>
              ✨ Combination Spotlight
            </h2>
            <button
              onClick={() => generateHighlightedCombos()}
              style={{
                padding: '0.5rem 1rem',
                background: 'rgba(244, 114, 182, 0.5)',
                border: 'none',
                borderRadius: '0.4rem',
                color: '#fff',
                fontWeight: '600',
                fontSize: '0.8rem',
                cursor: 'pointer',
              }}
            >
              Generate 3 More
            </button>
          </div>

          {highlightedCombos.length > 0 ? (
            <div style={{ display: 'flex', flexDirection: 'column', gap: '1rem' }}>
              {highlightedCombos.map((combo, i) => (
                <div key={i} style={{ padding: '1rem', background: 'rgba(0, 0, 0, 0.2)', borderRadius: '0.5rem' }}>
                  <p style={{ fontSize: '0.8rem', fontWeight: '600', color: '#ec4899', textTransform: 'uppercase', margin: '0 0 0.75rem 0', letterSpacing: '0.05em' }}>
                    Combination {String.fromCharCode(65 + i)}
                  </p>
                  <div style={{ display: 'flex', gap: '0.5rem', flexWrap: 'wrap' }}>
                    {combo.combo.map((opt, j) => (
                      <span
                        key={j}
                        style={{
                          padding: '0.4rem 0.75rem',
                          background: 'rgba(244, 114, 182, 0.3)',
                          border: '1px solid rgba(244, 114, 182, 0.6)',
                          borderRadius: '999px',
                          fontSize: '0.8rem',
                          fontWeight: '600',
                          color: '#f472b6',
                        }}
                      >
                        {opt}
                      </span>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          ) : (
            <div style={{ padding: '1rem', textAlign: 'center', color: '#a78bfa', fontSize: '0.9rem' }}>
              Click "Generate 3 More" to see random combination ideas
            </div>
          )}
        </div>

        {/* All Combinations */}
        <div style={{ background: 'rgba(244, 114, 182, 0.08)', border: '1px solid rgba(244, 114, 182, 0.3)', borderRadius: '1rem', padding: '2rem', marginBottom: '2rem' }}>
          {combinations.map((combo, i) => (
            combo.idea?.trim() && (
              <div key={i} style={{ marginBottom: i < combinations.length - 1 ? '2rem' : 0, paddingBottom: i < combinations.length - 1 ? '2rem' : 0, borderBottom: i < combinations.length - 1 ? '1px solid rgba(244, 114, 182, 0.2)' : 'none' }}>
                <div style={{ display: 'flex', gap: '0.5rem', flexWrap: 'wrap', marginBottom: '0.75rem' }}>
                  {combo.combo.map((opt, j) => (
                    <span
                      key={j}
                      style={{
                        padding: '0.3rem 0.6rem',
                        background: 'rgba(244, 114, 182, 0.2)',
                        border: '1px solid rgba(244, 114, 182, 0.5)',
                        borderRadius: '999px',
                        fontSize: '0.75rem',
                        fontWeight: '600',
                        color: '#f472b6',
                      }}
                    >
                      {opt}
                    </span>
                  ))}
                </div>
                <p style={{ margin: 0, fontSize: '0.9rem', lineHeight: '1.5', color: '#d4d4d8' }}>
                  {combo.idea}
                </p>
              </div>
            )
          ))}
        </div>

        {/* AI Insights */}
        {insights && (
          <div style={{ background: 'rgba(168, 85, 247, 0.15)', border: '1px solid rgba(168, 85, 247, 0.4)', borderRadius: '1rem', padding: '1.5rem', marginBottom: '2rem' }}>
            <h3 style={{ fontSize: '1rem', fontWeight: '700', color: '#a78bfa', margin: '0 0 1rem 0' }}>
              Design Insights
            </h3>
            <p style={{ margin: 0, fontSize: '0.95rem', lineHeight: '1.6', color: '#e0d5ff', whiteSpace: 'pre-wrap' }}>
              {insights}
            </p>
          </div>
        )}

        {loadingInsights && (
          <div style={{ textAlign: 'center', padding: '2rem' }}>
            <p style={{ color: '#a78bfa', fontSize: '0.95rem' }}>Analyzing combinations...</p>
          </div>
        )}

        {/* Actions */}
        <div style={{ display: 'flex', gap: '0.75rem' }}>
          <button
            onClick={() => {
              setStage('combinations');
              setNudgeVisible(false);
            }}
            style={{
              flex: 1,
              padding: '0.875rem',
              background: 'rgba(244, 114, 182, 0.3)',
              border: '1px solid rgba(244, 114, 182, 0.5)',
              borderRadius: '0.75rem',
              color: '#fff',
              fontWeight: '600',
              cursor: 'pointer',
              fontSize: '0.95rem',
            }}
          >
            Continue Exploring
          </button>
          <button
            onClick={() => window.print()}
            style={{
              flex: 1,
              padding: '0.875rem',
              background: 'linear-gradient(135deg, #ec4899 0%, #f472b6 100%)',
              border: 'none',
              borderRadius: '0.75rem',
              color: '#fff',
              fontWeight: '600',
              cursor: 'pointer',
              fontSize: '0.95rem',
            }}
          >
            Print
          </button>
        </div>
      </div>
    </div>
  </div>
    );
}
