# Preflight scanner environment configuration.
# Copy to .env for local dev; set as Fly secrets in prod via `fly secrets set`.

# Supabase project URL (public) and service-role key (SECRET — never commit).
# The service-role key is minted at Phase 2A-6 — not needed for 2A-1..2A-5
# because sub-phases run against MockSupabaseClient.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# How often the worker polls the fabrication_scan_jobs queue, in seconds.
POLL_INTERVAL_SECONDS=5

# Dry-run mode: worker reads jobs and computes scans, but does NOT write results
# back. Useful during 2A-1..2A-5 local development. Default false for prod.
DRY_RUN=false

# Structured-logging level: debug | info | warning | error.
LOG_LEVEL=info

# Set true while under Fly.io free trial to tag all log entries. Lets us grep
# for "billing=trial" when the trial expires. Optional.
BILLING_TAG=trial
