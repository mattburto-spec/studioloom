# ============================================================================
# StudioLoom (Questerra) Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in the actual values.
# REQUIRED variables must be set for the application to function.
# OPTIONAL variables enable specific features; app will gracefully degrade
# without them.
# ============================================================================

# ============================================================================
# REQUIRED: Core AI & Authentication
# ============================================================================

# Anthropic Claude API key for all AI generation features
# Get from: https://console.anthropic.com/keys
# Used for: Unit builder, knowledge base analysis, design assistant, toolkit
ANTHROPIC_API_KEY=sk-ant-...

# ============================================================================
# REQUIRED: Supabase (Database & Auth)
# ============================================================================

# Supabase project URL
# Get from: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous/public key (safe to expose in browser)
# Get from: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase service role key (KEEP SECRET — server-only)
# Get from: https://app.supabase.com → Project Settings → API
# Used for: Admin operations, knowledge base ingestion, design assistant
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================================
# REQUIRED: Embeddings (Knowledge Base)
# ============================================================================

# Voyage AI API key for vector embeddings
# Get from: https://www.voyageai.com/api-keys
# Used for: RAG retrieval, knowledge base chunking, semantic search
# Note: Questerra uses voyage-3.5 (1024-dim vectors)
VOYAGE_API_KEY=pa-...

# ============================================================================
# REQUIRED: Encryption (BYOK — Bring Your Own Key)
# ============================================================================

# 256-bit encryption key for storing user BYOK credentials (AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Used for: Encrypting teacher's personal API keys stored in database
ENCRYPTION_KEY=64-character-hex-string-here...

# ============================================================================
# OPTIONAL: Error Tracking & Monitoring
# ============================================================================

# Sentry DSN for error tracking and performance monitoring
# Get from: https://sentry.io → Project Settings
# Leave blank to disable Sentry
NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@yyyy.ingest.sentry.io/zzzzz

# Sentry auth token for uploading source maps during build
# Get from: https://sentry.io → Settings → Auth Tokens
# Only needed if uploading source maps; build succeeds without it
SENTRY_AUTH_TOKEN=sntrys_xxxxx

# ============================================================================
# OPTIONAL: AI Provider Fallbacks
# ============================================================================

# Groq API key (free tier, fast inference, OpenAI-compatible)
# Get from: https://console.groq.com
# Fallback if Anthropic key fails
GROQ_API_KEY=gsk_...

# Google Gemini API key (OpenAI-compatible endpoint)
# Get from: https://aistudio.google.com/apikey
# Secondary fallback after Groq
GEMINI_API_KEY=AIzaSy...

# ============================================================================
# OPTIONAL: Additional Features
# ============================================================================

# ElevenLabs API key for text-to-speech in interactive tools
# Get from: https://elevenlabs.io/api
# Leave blank to disable TTS features
ELEVENLABS_API_KEY=sk_...

# ============================================================================
# OPTIONAL: Admin & Access Control
# ============================================================================

# Comma-separated list of admin email addresses (can access /admin routes)
# Default: mattburto@gmail.com
# Example: admin1@example.com,admin2@example.com
ADMIN_EMAILS=mattburto@gmail.com
